# Copy this file to `.env.test.local` if you need local overrides for Vitest.

NODE_ENV=test

# Public base URL for the web app
NEXT_PUBLIC_APP_URL=http://localhost:4000

# Enable dev prefill for demo data in forms (register/reservation)
NEXT_PUBLIC_DEV_PREFILL=false

# Display hospital name/contact in reservation notifications
NEXT_PUBLIC_HOSPITAL_NAME=올바른정형외과
NEXT_PUBLIC_HOSPITAL_CONTACT="문의: 02-0000-0000"

# Default reservation capacity (overridden by admin rules)
NEXT_PUBLIC_RESERVATION_MAX_PER_SLOT=4
NEXT_PUBLIC_RESERVATION_MAX_PER_DAY=40

# Redis (used for real-time queue/reservations)
REDIS_URL=redis://redis:6379
USE_REDIS=false

# PostgreSQL (used for history/master data/accounts)
DATABASE_URL=postgresql://app:app@db:5432/allright
USE_DB=false

POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=allright

# Auth
JWT_SECRET=please-change-me

# Dev integration test helpers
ADMIN_SECRET=ADMINSECRETSAMPLE
