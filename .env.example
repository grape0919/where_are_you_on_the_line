# Copy this file to `.env` or `.env.docker` and adjust values.

NODE_ENV=development

# Public base URL for the web app
NEXT_PUBLIC_APP_URL=http://localhost:4000

# Enable dev prefill for demo data in forms
NEXT_PUBLIC_DEV_PREFILL=false

# Display hospital name/contact
NEXT_PUBLIC_HOSPITAL_NAME=올바른정형외과
NEXT_PUBLIC_HOSPITAL_CONTACT="문의: 02-0000-0000"

# PostgreSQL — 반드시 설정 필요 (InMemory 모드 제거됨)
DATABASE_URL=postgresql://app:app@db:5432/allright
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=allright

# Auth — 프로덕션 최소 8자 (권장: 16자+ 랜덤)
# 강력한 값 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=

# 알리고 SMS (https://smartsms.aligo.in)
# 3개 모두 설정되면 실제 SMS 발송, 하나라도 비면 콘솔 로그만 (개발 모드)
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER=     # 사전 등록된 발신번호 (병원 대표번호)
# ALIGO_TESTMODE=Y  # 테스트 모드 (실제 발송 없이 응답만, 요금 X)
